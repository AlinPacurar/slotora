generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String              @id @default(cuid())
  name                 String
  email                String              @unique
  password             String
  emailNotifications   Boolean             @default(true)
  plan                 String              @default("community")
  planExpiresAt        DateTime?
  createdAt            DateTime            @default(now())
  stripeCustomerId     String?
  stripeSubscriptionId String?
  polls                Poll[]
  ownedGroups          Group[]             @relation("OwnedGroups")
  groupMembers         GroupMember[]
  voucherRedemptions   VoucherRedemption[]
}

model Poll {
  id                     String    @id @default(cuid())
  title                  String
  description            String?
  creatorName            String
  dates                  String[]
  deviceVotes            Json      @default("{}")
  ipVotes                Json      @default("{}")
  times                  Json      @default("{}")
  votes                  Json      @default("{}")
  comments               Json      @default("{}")
  deadline               DateTime?
  closed                 Boolean   @default(false)
  deletedAt              DateTime?
  notifyOnVote           Boolean   @default(true)
  createdAt              DateTime  @default(now())
  userId                 String?
  user                   User?     @relation(fields: [userId], references: [id])
  voteOptions            String[]  @default([])
  collectParticipantData Boolean   @default(false)
}

model Group {
  id          String        @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime      @default(now())
  ownerId     String
  owner       User          @relation("OwnedGroups", fields: [ownerId], references: [id])
  members     GroupMember[]
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())
  group    Group    @relation(fields: [groupId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model Voucher {
  id           String              @id @default(cuid())
  code         String              @unique
  plan         String
  durationDays Int
  maxUses      Int                 @default(1)
  usedCount    Int                 @default(0)
  createdBy    String
  createdAt    DateTime            @default(now())
  expiresAt    DateTime?
  redemptions  VoucherRedemption[]
}

model VoucherRedemption {
  id         String   @id @default(cuid())
  voucherId  String
  userId     String
  redeemedAt DateTime @default(now())
  voucher    Voucher  @relation(fields: [voucherId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([voucherId, userId])
}
