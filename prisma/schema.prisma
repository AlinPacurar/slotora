generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String              @id @default(cuid())
  name                 String
  email                String              @unique
  password             String
  createdAt            DateTime            @default(now())
  emailNotifications   Boolean             @default(true)
  plan                 String              @default("community")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planExpiresAt        DateTime?
  ownedGroups          Group[]             @relation("OwnedGroups")
  groupMembers         GroupMember[]
  polls                Poll[]
  voucherRedemptions   VoucherRedemption[]
  sentInvites GroupInvite[] @relation("SentInvites")
}

model Poll {
  id                     String    @id @default(cuid())
  title                  String
  description            String?
  creatorName            String
  dates                  String[]
  votes                  Json      @default("{}")
  createdAt              DateTime  @default(now())
  userId                 String?
  closed                 Boolean   @default(false)
  comments               Json      @default("{}")
  deadline               DateTime?
  deletedAt              DateTime?
  notifyOnVote           Boolean   @default(true)
  voteOptions            String[]  @default([])
  collectParticipantData Boolean   @default(false)
  times                  Json      @default("{}")
  deviceVotes            Json      @default("{}")
  ipVotes                Json      @default("{}")
  user                   User?     @relation(fields: [userId], references: [id])
}

model Group {
  id          String        @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime      @default(now())
  ownerId     String
  slug        String        @unique
  isPublic    Boolean       @default(false)
  inviteCode  String        @unique
  joinPolicy  String        @default("request")
  avatarUrl   String?
  owner       User          @relation("OwnedGroups", fields: [ownerId], references: [id])
  members     GroupMember[]
  invites     GroupInvite[]
  
}

model GroupMember {
  id           String   @id @default(cuid())
  groupId      String
  userId       String
  role         String   @default("member")
  joinedAt     DateTime @default(now())
  status       String   @default("active")
  invitedEmail String?
  group        Group    @relation(fields: [groupId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model GroupInvite {
  id        String    @id @default(uuid())
  token     String    @unique @default(uuid())
  groupId   String
  email     String
  role      String    @default("member")
  invitedBy String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter   User      @relation("SentInvites", fields: [invitedBy], references: [id], onDelete: Cascade)
}

model Voucher {
  id           String              @id @default(cuid())
  code         String              @unique
  plan         String
  durationDays Int
  maxUses      Int                 @default(1)
  usedCount    Int                 @default(0)
  createdBy    String
  createdAt    DateTime            @default(now())
  expiresAt    DateTime?
  redemptions  VoucherRedemption[]
}

model VoucherRedemption {
  id         String   @id @default(cuid())
  voucherId  String
  userId     String
  redeemedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  voucher    Voucher  @relation(fields: [voucherId], references: [id])

  @@unique([voucherId, userId])
}
