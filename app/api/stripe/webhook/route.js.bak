export const dynamic = "force-dynamic";
// app/api/webhooks/stripe/route.js

import { NextResponse } from "next/server";
import Stripe from "stripe";
import { prisma } from "@/lib/db";

const stripe = new Stripe(process.env.STRIPE_SECRET_KEY);

const PRICE_TO_PLAN = {
  [process.env.STRIPE_SLOT_MONTHLY]: "slot",
  [process.env.STRIPE_SLOT_YEARLY]: "slot",
  [process.env.STRIPE_SNAP_MONTHLY]: "snap",
  [process.env.STRIPE_SNAP_YEARLY]: "snap",
  [process.env.STRIPE_ORA_MONTHLY]: "ora",
  [process.env.STRIPE_ORA_YEARLY]: "ora",
};

async function getUserIdFromCustomer(customerId) {
  const user = await prisma.user.findFirst({
    where: { stripeCustomerId: customerId },
    select: { id: true },
  });
  return user?.id ?? null;
}

async function getPlanFromSubscription(subscription) {
  if (subscription.metadata?.plan) return subscription.metadata.plan;
  const priceId = subscription.items?.data?.[0]?.price?.id;
  return priceId ? (PRICE_TO_PLAN[priceId] ?? null) : null;
}

/**
 * Derive planExpiresAt from a Stripe subscription object.
 * - Active subscription: null (Stripe manages it, no hard expiry needed)
 * - Cancelled at period end: current_period_end (access until then)
 * - Deleted/ended: now (expire immediately)
 */
function getPlanExpiresAt(subscription, isDeleted = false) {
  if (isDeleted) return new Date();
  if (subscription.cancel_at_period_end && subscription.current_period_end) {
    return new Date(subscription.current_period_end * 1000);
  }
  // Active subscription managed by Stripe — no hard client-side expiry
  return null;
}

export async function POST(request) {
  const body = await request.text();
  const sig = request.headers.get("stripe-signature");

  let event;
  try {
    event = stripe.webhooks.constructEvent(body, sig, process.env.STRIPE_WEBHOOK_SECRET);
  } catch (err) {
    console.error("Webhook signature error:", err.message);
    return NextResponse.json({ error: "Invalid signature" }, { status: 400 });
  }

  try {
    switch (event.type) {

      // ── New subscription created via Checkout ────────────────────────────
      case "checkout.session.completed": {
        const session = event.data.object;
        const { userId, plan } = session.metadata ?? {};
        if (userId && plan) {
          await prisma.user.update({
            where: { id: userId },
            data: {
              plan,
              planExpiresAt: null,    // active Stripe sub — no expiry
              stripeCustomerId: session.customer,
              stripeSubscriptionId: session.subscription,
            },
          });
          console.log(`[webhook] checkout.session.completed: user ${userId} → ${plan}`);
        }
        break;
      }

      // ── Subscription changed (upgrade, downgrade, cancel, past_due) ──────
      case "customer.subscription.updated": {
        const subscription = event.data.object;
        const userId = subscription.metadata?.userId
          ?? await getUserIdFromCustomer(subscription.customer);
        if (!userId) break;

        const { status, cancel_at_period_end } = subscription;

        if (status === "active" && !cancel_at_period_end) {
          // Normal active — sync plan, clear expiry
          const plan = await getPlanFromSubscription(subscription);
          if (plan) {
            await prisma.user.update({
              where: { id: userId },
              data: {
                plan,
                planExpiresAt: null,
                stripeSubscriptionId: subscription.id,
              },
            });
            console.log(`[webhook] subscription.updated: user ${userId} → ${plan} (active)`);
          }

        } else if (status === "active" && cancel_at_period_end) {
          // Cancelled but still in grace period — keep plan, set expiry date
          const plan = await getPlanFromSubscription(subscription);
          const planExpiresAt = getPlanExpiresAt(subscription);
          if (plan) {
            await prisma.user.update({
              where: { id: userId },
              data: { plan, planExpiresAt },
            });
            console.log(`[webhook] subscription.updated: user ${userId} cancel scheduled → expires ${planExpiresAt}`);
          }

        } else if (status === "past_due" || status === "unpaid") {
          // Payment failed — downgrade immediately
          await prisma.user.update({
            where: { id: userId },
            data: { plan: "community", planExpiresAt: null },
          });
          console.log(`[webhook] subscription.updated: user ${userId} ${status} → community`);

        } else if (status === "canceled") {
          await prisma.user.update({
            where: { id: userId },
            data: { plan: "community", planExpiresAt: null, stripeSubscriptionId: null },
          });
          console.log(`[webhook] subscription.updated: user ${userId} canceled → community`);
        }
        break;
      }

      // ── Subscription fully ended ─────────────────────────────────────────
      case "customer.subscription.deleted": {
        const subscription = event.data.object;
        const userId = subscription.metadata?.userId
          ?? await getUserIdFromCustomer(subscription.customer);
        if (userId) {
          await prisma.user.update({
            where: { id: userId },
            data: { plan: "community", planExpiresAt: null, stripeSubscriptionId: null },
          });
          console.log(`[webhook] subscription.deleted: user ${userId} → community`);
        }
        break;
      }

      // ── Payment failed (invoice) ─────────────────────────────────────────
      case "invoice.payment_failed": {
        const invoice = event.data.object;
        const userId = await getUserIdFromCustomer(invoice.customer);
        // subscription.updated with past_due handles the actual downgrade.
        // Hook this up to a "payment failed" email in future.
        console.log(`[webhook] invoice.payment_failed: customer ${invoice.customer} (userId: ${userId})`);
        break;
      }

      // ── Full refund issued ───────────────────────────────────────────────
      case "charge.refunded": {
        const charge = event.data.object;
        if (charge.refunded && charge.amount_refunded === charge.amount) {
          const userId = await getUserIdFromCustomer(charge.customer);
          if (userId) {
            await prisma.user.update({
              where: { id: userId },
              data: { plan: "community", planExpiresAt: null, stripeSubscriptionId: null },
            });
            console.log(`[webhook] charge.refunded (full): user ${userId} → community`);
          }
        } else {
          console.log(`[webhook] charge.refunded (partial): customer ${charge.customer}`);
        }
        break;
      }

    }

    return NextResponse.json({ received: true });
  } catch (error) {
    console.error("Webhook error:", error);
    return NextResponse.json({ error: "Webhook failed" }, { status: 500 });
  }
}